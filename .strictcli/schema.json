{
  "commands": {
    "bisect": {
      "help": "bisect (guarded)",
      "name": "bisect",
      "passthrough": true
    },
    "checkout": {
      "help": "checkout a ref (guarded)",
      "name": "checkout",
      "passthrough": true
    },
    "cherry-pick": {
      "help": "cherry-pick commits (guarded)",
      "name": "cherry-pick",
      "passthrough": true
    },
    "commit": {
      "args": [
        {
          "help": "files to commit (supports hunk specs: file.go:1,3)",
          "name": "files",
          "required": false,
          "variadic": true
        }
      ],
      "flags": [
        {
          "default": [],
          "help": "commit message (repeatable)",
          "name": "m",
          "repeatable": true,
          "short": "m",
          "type": "str"
        },
        {
          "help": "read commit message from file",
          "name": "F",
          "short": "F",
          "type": "str"
        },
        {
          "help": "commit to a different branch",
          "name": "branch",
          "type": "str"
        },
        {
          "default": false,
          "help": "amend the current HEAD commit",
          "name": "amend",
          "negatable": true,
          "type": "bool"
        },
        {
          "default": false,
          "help": "allow commits with no file changes",
          "name": "allow-empty",
          "negatable": true,
          "type": "bool"
        },
        {
          "default": [],
          "help": "add a trailer (repeatable)",
          "name": "trailer",
          "repeatable": true,
          "type": "str"
        }
      ],
      "help": "stage and commit files atomically",
      "name": "commit"
    },
    "doctor": {
      "flags": [
        {
          "default": false,
          "help": "run health checks without fixing",
          "name": "diagnose",
          "negatable": true,
          "type": "bool"
        },
        {
          "default": false,
          "help": "run health checks and fix issues",
          "name": "fix",
          "negatable": true,
          "type": "bool"
        },
        {
          "default": false,
          "help": "remove safegit from this repository",
          "name": "uninstall",
          "negatable": true,
          "type": "bool"
        }
      ],
      "help": "health checks and repair",
      "name": "doctor"
    },
    "merge": {
      "help": "merge a branch (guarded)",
      "name": "merge",
      "passthrough": true
    },
    "pull": {
      "args": [
        {
          "help": "remote name",
          "name": "remote",
          "required": false
        },
        {
          "help": "branch to pull",
          "name": "branch",
          "required": false
        }
      ],
      "flags": [
        {
          "default": false,
          "help": "fast-forward only (fail if not possible)",
          "name": "ff-only",
          "negatable": true,
          "type": "bool"
        },
        {
          "default": false,
          "help": "fast-forward if possible, merge commit otherwise",
          "name": "ff",
          "negatable": true,
          "type": "bool"
        },
        {
          "default": false,
          "help": "always create a merge commit",
          "name": "no-ff",
          "negatable": true,
          "type": "bool"
        }
      ],
      "help": "fetch and merge (default --ff-only)",
      "name": "pull"
    },
    "push": {
      "args": [
        {
          "help": "remote name",
          "name": "remote",
          "required": false
        },
        {
          "help": "refs to push",
          "name": "refspecs",
          "required": false,
          "variadic": true
        }
      ],
      "flags": [
        {
          "default": false,
          "help": "skip pre-pre-push hooks",
          "name": "no-pre-pre-push",
          "negatable": true,
          "type": "bool"
        },
        {
          "default": false,
          "help": "force push to remote",
          "name": "force-push",
          "negatable": true,
          "type": "bool"
        }
      ],
      "help": "push with pre-hooks and retry",
      "name": "push"
    },
    "rebase": {
      "help": "rebase onto upstream (guarded)",
      "name": "rebase",
      "passthrough": true
    },
    "redo": {
      "flags": [
        {
          "default": false,
          "help": "redo across all sessions, ignoring session ID",
          "name": "bypass-session",
          "negatable": true,
          "type": "bool"
        }
      ],
      "help": "restore what undo removed (one-shot)",
      "name": "redo"
    },
    "reset": {
      "help": "reset HEAD (guarded for --hard)",
      "name": "reset",
      "passthrough": true
    },
    "revert": {
      "help": "revert commits (guarded)",
      "name": "revert",
      "passthrough": true
    },
    "rewrite-author": {
      "flags": [
        {
          "help": "current author/committer name to match",
          "name": "old-name",
          "type": "str"
        },
        {
          "help": "replacement name",
          "name": "new-name",
          "type": "str"
        },
        {
          "help": "current author/committer email to match",
          "name": "old-email",
          "type": "str"
        },
        {
          "help": "replacement email",
          "name": "new-email",
          "type": "str"
        },
        {
          "default": false,
          "help": "force-push after rewriting",
          "name": "push",
          "negatable": true,
          "type": "bool"
        }
      ],
      "help": "rewrite author/committer across history",
      "name": "rewrite-author"
    },
    "undo": {
      "flags": [
        {
          "default": false,
          "help": "undo across all sessions, ignoring session ID",
          "name": "bypass-session",
          "negatable": true,
          "type": "bool"
        }
      ],
      "help": "reverse last commit/amend/reword via oplog",
      "name": "undo"
    },
    "unlock": {
      "args": [
        {
          "help": "the ref name to unlock",
          "name": "ref"
        }
      ],
      "help": "release a stale ref lock",
      "name": "unlock"
    },
    "version": {
      "help": "print version and build info",
      "name": "version"
    }
  },
  "defaults": {
    "app": {
      "commands": {},
      "config": false,
      "deprecated": {},
      "env_prefix": null,
      "global_flags": [],
      "groups": {}
    },
    "arg": {
      "required": true,
      "variadic": false
    },
    "command": {
      "args": [],
      "flags": [],
      "passthrough": false
    },
    "flag": {
      "choices": null,
      "default": null,
      "env": null,
      "hidden": false,
      "negatable": null,
      "repeatable": false,
      "short": null
    },
    "group": {
      "commands": {},
      "deprecated": {},
      "groups": {}
    }
  },
  "global_flags": [
    {
      "default": false,
      "help": "suppress non-essential output",
      "name": "quiet",
      "negatable": true,
      "short": "q",
      "type": "bool"
    },
    {
      "default": false,
      "help": "verbose output",
      "name": "verbose",
      "negatable": true,
      "type": "bool"
    },
    {
      "default": false,
      "help": "preview changes without writing",
      "name": "dry-run",
      "negatable": true,
      "short": "n",
      "type": "bool"
    },
    {
      "default": false,
      "help": "force operation",
      "name": "force",
      "negatable": true,
      "short": "f",
      "type": "bool"
    },
    {
      "default": "",
      "help": "config file path",
      "name": "config",
      "type": "str"
    }
  ],
  "groups": {
    "config": {
      "commands": {
        "get": {
          "args": [
            {
              "help": "configuration key",
              "name": "key"
            }
          ],
          "help": "get the current value of a single configuration key from the .git/safegit/config.json file, printing the raw value to stdout so it can be captured by scripts or used in automation pipelines",
          "name": "get"
        },
        "set": {
          "args": [
            {
              "help": "configuration key",
              "name": "key"
            },
            {
              "help": "configuration value",
              "name": "value"
            }
          ],
          "help": "set a configuration key to a new value in the .git/safegit/config.json file, creating the file if it does not exist yet, and persisting the change for all future safegit invocations in this repository",
          "name": "set"
        },
        "show": {
          "help": "show all configuration values currently in effect for this repository, including built-in defaults and any user overrides from the .git/safegit/config.json file, printed as key-value pairs to stdout for inspection and debugging purposes",
          "name": "show"
        }
      },
      "help": "show or set configuration values",
      "name": "config"
    },
    "hook": {
      "commands": {
        "install": {
          "args": [
            {
              "help": "path to hook script",
              "name": "path"
            }
          ],
          "help": "install a pre-pre-push hook by copying a script file into the .git/safegit/hooks directory, making it executable, and registering it so that safegit push will run it before any network I/O occurs",
          "name": "install"
        },
        "list": {
          "help": "list all pre-pre-push hooks currently installed in the .git/safegit/hooks directory, showing each hook name, file path, and whether it is executable, so you can audit which checks run before every push",
          "name": "list"
        },
        "run": {
          "args": [
            {
              "help": "hook name to run",
              "name": "name",
              "required": false
            }
          ],
          "help": "run all installed pre-pre-push hooks (or a single named hook) immediately without performing an actual push, so you can verify that all configured hooks pass before committing to a real push operation",
          "name": "run"
        }
      },
      "help": "manage pre-pre-push hooks",
      "name": "hook"
    },
    "scrub": {
      "commands": {
        "file": {
          "args": [
            {
              "help": "repo-relative file path to scrub",
              "name": "file"
            }
          ],
          "flags": [
            {
              "help": "first commit to include in the rewrite",
              "name": "from",
              "type": "str"
            },
            {
              "help": "audit trail explaining why the scrub is needed",
              "name": "reason",
              "type": "str"
            }
          ],
          "help": "replace or remove a specific file across all commits in the repository history, rewriting each affected commit tree to either substitute the file contents with a sanitized version or delete the file entirely from every historical snapshot",
          "name": "file"
        },
        "match": {
          "flags": [
            {
              "help": "regex pattern to search for",
              "name": "pattern",
              "type": "str"
            },
            {
              "help": "replacement string",
              "name": "replace",
              "type": "str"
            },
            {
              "help": "audit trail explaining why the scrub is needed",
              "name": "reason",
              "type": "str"
            },
            {
              "help": "glob pattern limiting which file paths are searched (e.g. '*.env', 'config/**')",
              "name": "scope",
              "type": "str"
            },
            {
              "help": "first commit to include in the rewrite",
              "name": "from",
              "type": "str"
            },
            {
              "default": false,
              "help": "rewrite all commits",
              "name": "entire-history",
              "negatable": true,
              "type": "bool"
            }
          ],
          "help": "replace all occurrences of a regex pattern across every blob in the repository history, rewriting commit trees to substitute matched text with a replacement string so that sensitive values like secrets and credentials are permanently removed from all historical snapshots",
          "name": "match"
        }
      },
      "help": "surgically rewrite git history to remove or replace sensitive content such as secrets, credentials, and private data from all commits, trees, and blobs in the repository",
      "name": "scrub"
    }
  },
  "help": "concurrency-safe git for multi-agent use",
  "name": "safegit",
  "project_id": "github.com/smm-h/safegit",
  "version": "0.14.1+dirty"
}
