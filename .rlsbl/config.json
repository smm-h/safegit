{
  "targets": [
    "go",
    "docker"
  ],
  "pipelines": {
    "go": {
      "type": "go",
      "local": true
    },
    "docker": {
      "type": "docker",
      "local": false
    }
  },
  "private": false,
  "push_timeout": 120,
  "batch_limits": {
    "exclusions": []
  },
  "hooks": {
    "pre_release": [
      "go vet ./...",
      "go build -o /dev/null .",
      "go test ./... -race -short -count=1"
    ]
  }
}
