{
  "targets": [
    "go",
    "docker"
  ],
  "pipelines": {
    "go": {
      "type": "go",
      "local": true
    },
    "docker": {
      "type": "docker",
      "local": false
    }
  },
  "private": false,
  "push_timeout": 120,
  "batch_limits": {
    "exclusions": [
      {
        "reason": "non-user-facing batch",
        "entries": [
          {
            "version": "unreleased",
            "line": 11
          }
        ]
      }
    ]
  }
}
